# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Swagger API docs: defaults on outside production, off in production.
# Set to true/false to override (e.g. expose docs in production behind nginx auth).
ENABLE_API_DOCS=

# PostgreSQL (primary relational store)
DATABASE_URL=postgres://sreedo:sreedo@localhost:5432/sreedo

# MongoDB (audit logs + AI conversation history) — optional, features degrade gracefully
MONGO_URL=mongodb://localhost:27017
MONGO_DB=sreedo

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# Public base URL of the web app (used to build password-reset links in email).
# Falls back to the first CORS_ORIGIN when unset.
APP_PUBLIC_URL=http://localhost:3000
# Self-service password-reset token lifetime (minutes)
PASSWORD_RESET_TTL_MINUTES=60

# Per-account lockout (brute-force protection)
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
# Per-tenant cap for the external /ext API (keyed by institution, not IP)
TENANT_RATE_LIMIT_MAX=600

# OpenAI (AI assistant) — optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# AI Copilot (PR-T11, read-only) — cost/abuse guards; the surface is also gated
# by the per-tenant opt-in flag settings.featureFlags.aiCopilot === true.
COPILOT_RATE_LIMIT_PER_MINUTE=6
COPILOT_MAX_TURNS_PER_USER_PER_DAY=50
COPILOT_MAX_TOKENS=700

# SMTP (transactional email) — optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SRE EDU OS <no-reply@sreedo.edu>"

# SMS adapter — optional (provider-agnostic; degrades to no-op when unset)
SMS_PROVIDER=
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER=SREEDO

# Firebase Cloud Messaging (push) — optional (degrades to no-op when unset)
FCM_SERVER_KEY=

# Object storage (S3-compatible) — optional; falls back to local disk (dev) when unset
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_LOCAL_DIR=uploads
STORAGE_MAX_MB=10

# Online payment gateway — optional (provider-agnostic hosted checkout).
# When PAYMENT_GATEWAY_PROVIDER + PAYMENT_GATEWAY_WEBHOOK_SECRET are unset, online
# payments are "not configured" and degrade gracefully (offline fee collection
# keeps working). Never commit real provider credentials. No card/bank/UPI data
# is stored — only non-sensitive provider order/payment references.
PAYMENT_GATEWAY_PROVIDER=
PAYMENT_GATEWAY_WEBHOOK_SECRET=
PAYMENT_CHECKOUT_BASE_URL=
PAYMENT_CURRENCY=INR

# Platform SaaS-invoice payment gateway (Razorpay) — optional. The super admin
# normally enters these in the masked Payment Gateway settings UI; these env vars
# are only a fallback for the secrets when the DB fields are left blank. When no
# key id/secret is configured the gateway is off and SaaS invoices are collected
# offline (mark-paid) as before. Never commit real credentials.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_API_BASE=https://api.razorpay.com/v1

# Background job worker — Postgres-backed (no external broker). Off by default;
# set JOB_WORKER_ENABLED=true in self-hosted deployments to run the scheduler tick
# + drain the queue on an interval. CI/tests drive the worker via the API instead.
JOB_WORKER_ENABLED=
JOB_WORKER_INTERVAL_MS=15000

# Subscription lifecycle (Billing Phase B1). The sweep marks expired
# subscriptions and sends renewal reminders; it runs in the worker tick (when
# JOB_WORKER_ENABLED) or on demand via POST /platform/subscriptions/run-lifecycle.
# Days of grace after a term ends before a subscription is marked expired.
BILLING_GRACE_DAYS=14
# Days-before-expiry on which to send a renewal reminder (comma-separated).
BILLING_REMINDER_DAYS=14,7,1
# When true, an expired subscription also suspends the institution. Off = the
# sweep is non-disruptive (status changes + reminders only).
BILLING_AUTO_SUSPEND=
# When true, requireActiveSubscription blocks writes for expired/suspended
# tenants. Off by default (the placeholder guard is not yet mounted on routes).
BILLING_ENFORCE_SUBSCRIPTION=

# SaaS invoicing (Billing Phase B2) — gateway-free. Invoice number prefix and
# default currency for operator-issued subscription invoices (paid offline).
SAAS_INVOICE_PREFIX=SINV-
SAAS_INVOICE_CURRENCY=INR
# Operator/seller identity printed on the invoice PDF "from" block. Only the name
# has a default; the rest are optional and omitted from the PDF when left blank.
SAAS_COMPANY_NAME=SRE EDU OS
SAAS_COMPANY_ADDRESS=
SAAS_COMPANY_EMAIL=
SAAS_COMPANY_GSTIN=
# Absolute path to a logo image (PNG/JPG) embedded in the PDF header; optional.
SAAS_COMPANY_LOGO_PATH=
