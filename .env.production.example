# Production environment for docker-compose.yml on a single VPS.
# Copy to `.env` next to docker-compose.yml and fill in real values.
# NEVER commit the filled-in .env — only this template.
#
# Generate strong secrets with:  openssl rand -base64 48

# --- PostgreSQL (data persists in the `pgdata` volume) ---
POSTGRES_USER=sreedo
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password__
POSTGRES_DB=sreedo

# --- JWT / auth secrets (REQUIRED; must NOT start with "dev-") ---
JWT_ACCESS_SECRET=__CHANGE_ME__openssl_rand_base64_48__
JWT_REFRESH_SECRET=__CHANGE_ME__different_openssl_rand_base64_48__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# --- Public URLs (REQUIRED) ---
# CORS_ORIGIN: the browser origin(s) allowed to call the API (comma-separated).
CORS_ORIGIN=https://erp.example.com
# NEXT_PUBLIC_API_URL: browser-visible API base, baked into the frontend at build.
NEXT_PUBLIC_API_URL=https://erp.example.com/api/v1
# APP_PUBLIC_URL: web app base used in transactional emails (e.g. password reset).
APP_PUBLIC_URL=https://erp.example.com
# Self-service password-reset token lifetime (minutes)
PASSWORD_RESET_TTL_MINUTES=60

# --- First-boot bootstrap ---
# Set true for the FIRST deploy only to seed the initial super admin, then set
# false and redeploy. (Seeding is skipped automatically if users already exist.)
SEED_ON_START=false

# --- API docs: keep OFF in production ---
ENABLE_API_DOCS=false

# --- Rate limiting (defaults are sane; tune if needed) ---
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
# Per-tenant cap for the external /ext API (keyed by institution, not IP)
TENANT_RATE_LIMIT_MAX=600

# --- Background worker (scheduler tick → scheduled backups + due jobs) ---
JOB_WORKER_ENABLED=true
JOB_WORKER_INTERVAL_MS=15000

# --- Object storage (S3-compatible) — RECOMMENDED in production ---
# Durable storage for UPLOADED DOCUMENTS ONLY (student files, ID cards, logos).
# This does NOT move database backups off-site: DB backups stay on the app-server
# disk unless you separately enable off-site backups in Backups settings
# (backup_settings.offsite_enabled). Setting these is safe on an existing instance —
# documents already on local disk stay readable (each file is served from the backend
# it was written to); only NEW uploads use S3. Leave blank to keep using local disk.
# STORAGE_REGION must match your bucket's region (e.g. ap-south-1 for Mumbai).
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_MAX_MB=10

# --- Document encryption at rest (RECOMMENDED — encrypt uploads "from our side") ---
# Encrypts uploaded documents with AES-256-GCM before they are written to disk/S3, so
# a stolen disk or leaked backup exposes only ciphertext. Generate a 32-byte key:
#   openssl rand -base64 32
# BACK THIS KEY UP SAFELY (a password manager) — if it is lost, encrypted files are
# unrecoverable. Existing plaintext files stay readable; only NEW uploads are encrypted.
DOCUMENT_ENCRYPTION_KEY=
DOCUMENT_ENCRYPTION_KEY_ID=k1
# Optional retired keys for rotation (decrypt-only), JSON: {"k0":"<base64 key>"}
DOCUMENT_ENCRYPTION_RETIRED_KEYS=

# --- Email (SMTP) — optional (fee reminders, scheduled report delivery) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SRE EDU OS <no-reply@erp.example.com>

# --- SMS — optional (provider-agnostic; no-op when unset) ---
SMS_PROVIDER=
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER=SREEDO

# --- Push notifications (FCM) — optional ---
FCM_SERVER_KEY=

# --- AI assistant (OpenAI) — optional ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Online payment gateway — optional (never commit real provider creds) ---
PAYMENT_GATEWAY_PROVIDER=
PAYMENT_GATEWAY_WEBHOOK_SECRET=
PAYMENT_CHECKOUT_BASE_URL=
PAYMENT_CURRENCY=INR

# --- Platform SaaS-invoice payment gateway (Razorpay) — optional ---
# For collecting SaaS/subscription invoice payments from institutions (super-admin
# billing). The super admin normally enters these in the masked Payment Gateway
# settings UI; these env vars are only a fallback for the secrets when the DB
# fields are left blank. When nothing is configured the gateway stays off and
# invoices are handled offline (mark-paid) as before. Never commit real credentials.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_API_BASE=https://api.razorpay.com/v1
