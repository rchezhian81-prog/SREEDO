# Docker Compose environment — copy to .env and adjust before `docker compose up`

# PostgreSQL
POSTGRES_USER=sreedo
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=sreedo

# JWT (use long random strings in production, e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# Seed demo data (admin user, classes, students) on first boot
SEED_ON_START=true

# Teacher own-class row scoping (PR-SEC1). Off by default — when true, a teacher
# without the academics:all_sections broad-view permission is limited to their
# own sections for attendance, exam marks and homework (school mode only). Turn
# on per school only after teacher→section data is confirmed populated.
ENFORCE_TEACHER_SCOPE=false

# Tenant suspension enforcement (PR-SEC2). Off by default — when true, a suspended
# or inactive institution's users are blocked at login and on every request
# (super_admin + audited support sessions exempt; fails open on DB error).
ENFORCE_TENANT_SUSPENSION=false

# Background job worker (Postgres-backed). Off by default; set true to run the
# scheduler tick + drain the queue on an interval in self-hosted deployments.
JOB_WORKER_ENABLED=false
JOB_WORKER_INTERVAL_MS=15000

# Expose Swagger API docs (/api/docs). Off in the production stack by default.
ENABLE_API_DOCS=false

# Public URL the browser uses to reach the API (through nginx)
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# Public base URL of the web app (used to build password-reset links in email).
# Defaults to the first CORS origin when unset.
APP_PUBLIC_URL=http://localhost
# Self-service password-reset token lifetime (minutes)
PASSWORD_RESET_TTL_MINUTES=60
# Per-account lockout (brute-force protection)
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Optional integrations
OPENAI_API_KEY=
# AI Copilot (read-only assistant; also needs the per-tenant aiCopilot flag)
COPILOT_RATE_LIMIT_PER_MINUTE=6
COPILOT_MAX_TURNS_PER_USER_PER_DAY=50
COPILOT_MAX_TOKENS=700
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SRE EDU OS <no-reply@sreedo.edu>"

# SMS adapter (optional) + Firebase Cloud Messaging push (optional)
SMS_PROVIDER=
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER=SREEDO
FCM_SERVER_KEY=

# Object storage (S3-compatible, optional) — local-disk fallback when unset
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_MAX_MB=10

# Online payment gateway (optional, provider-agnostic hosted checkout).
# Unset = online payments disabled, offline collection unaffected. Never commit
# real credentials; no card/bank/UPI data is ever stored.
PAYMENT_GATEWAY_PROVIDER=
PAYMENT_GATEWAY_WEBHOOK_SECRET=
PAYMENT_CHECKOUT_BASE_URL=
PAYMENT_CURRENCY=INR

# Platform SaaS-invoice payment gateway (Razorpay) — optional fallback for the
# secrets; the super admin normally sets these in the masked settings UI. Unset =
# gateway off, SaaS invoices collected offline. Never commit real credentials.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
