# Production Nginx with TLS. Copy to infra/nginx/production.conf, replace
# erp.example.com with your domain, obtain certs (certbot), then mount this file +
# /etc/letsencrypt into the nginx service and publish :443 (see docs/DEPLOYMENT.md).

upstream frontend { server frontend:3000; }
upstream backend  { server backend:4000; }

# HTTP :80 — serve the ACME challenge, redirect everything else to HTTPS.
server {
    listen 80;
    server_name erp.example.com;

    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$host$request_uri; }
}

# HTTPS :443 — terminate TLS and reverse-proxy.
server {
    listen 443 ssl;
    http2 on;
    server_name erp.example.com;

    ssl_certificate     /etc/letsencrypt/live/erp.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/erp.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    # Must be >= STORAGE_MAX_MB (default 10) so uploads/backups aren't truncated.
    client_max_body_size 10m;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript image/svg+xml;

    # Security headers (HSTS only over HTTPS).
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header X-XSS-Protection "0" always;

    # Swagger stays disabled in the backend in production (ENABLE_API_DOCS=false).
    # If you ever enable it, also restrict it here to trusted IPs:
    #   location /api/docs { allow 203.0.113.10; deny all; proxy_pass http://backend; }
    #   location = /api/docs.json { allow 203.0.113.10; deny all; proxy_pass http://backend; }

    location /api/ {
        proxy_pass http://backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Public health/readiness probes (no secrets, no auth).
    location ~ ^/(health|ready|live)$ {
        proxy_pass http://backend;
        proxy_set_header Host $host;
        access_log off;
    }

    location / {
        proxy_pass http://frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
